# ─────────────────────────────────────────────────────────────
#  Dograh AI — Türkçe Sesli Asistan Platformu
#  Ortam Değişkenleri
#
#  ÜRETİM ORTAMI İÇİN: Aşağıdaki varsayılan değerleri değiştirin!
# ─────────────────────────────────────────────────────────────

# ── GENEL ─────────────────────────────────────────────────────
# "local" = yerel geliştirme, "production" = üretim
ENVIRONMENT=local

# ── DOCKER REGISTRY ──────────────────────────────────────────
# Dograh resmi imajları (değiştirmeyin)
REGISTRY=ghcr.io/dograh-hq

# ── VERİTABANI ────────────────────────────────────────────────
POSTGRES_PASSWORD=postgres

# ── REDIS ─────────────────────────────────────────────────────
REDIS_PASSWORD=redissecret

# ── MİNİO (Nesne Depolama) ───────────────────────────────────
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# ── JWT GÜVENLİK ─────────────────────────────────────────────
# ÜRETİM ORTAMI İÇİN: Güvenli bir değer üretin:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
OSS_JWT_SECRET=ChangeMeInProduction

# ── BACKEND URL ──────────────────────────────────────────────
# Yerel: http://localhost:8000
# VPS: https://your-domain.com veya http://VPS_IP:8000
BACKEND_API_ENDPOINT=http://localhost:8000
BACKEND_URL=http://api:8000

# ── TELEMETRİ ────────────────────────────────────────────────
# false = anonim kullanım verisi gönderilmez
ENABLE_TELEMETRY=false

# ── FASTAPI ──────────────────────────────────────────────────
FASTAPI_WORKERS=1

# ── TURN SERVER (Uzak Sunucu WebRTC İçin) ────────────────────
# VPS kurulumunda TURN_HOST ve TURN_SECRET doldurun
TURN_HOST=
TURN_SECRET=
