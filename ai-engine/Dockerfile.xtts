FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y \
    ffmpeg \
    libsndfile1 \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir \
    gtts \
    fastapi \
    uvicorn

COPY tts/ ./tts/

EXPOSE 5002

CMD ["uvicorn", "tts.xtts_service:app", "--host", "0.0.0.0", "--port", "5002"]
