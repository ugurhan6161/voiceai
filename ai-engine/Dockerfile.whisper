FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y \
    ffmpeg \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir \
    faster-whisper \
    fastapi \
    uvicorn \
    python-multipart

COPY stt/ ./stt/

EXPOSE 9000

CMD ["uvicorn", "stt.whisper_service:app", "--host", "0.0.0.0", "--port", "9000"]
