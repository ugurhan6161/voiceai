# VoiceAI Platform — Ortam Değişkenleri v2.0
# cp .env.example .env → değerleri doldur → git'e gönderme!

# ── GENEL ─────────────────────────────────────────────────────
APP_ENV=production
APP_DOMAIN=your-domain.com
APP_SECRET_KEY=cok-uzun-ve-rastgele-bir-string-buraya

# ── ŞİFRELEME (KRİTİK) ───────────────────────────────────────
# Üretmek için: python3 -c "import secrets; print(secrets.token_hex(32))"
# Tüm API anahtarları ve şifreler bu anahtarla AES-256-GCM şifrelenir.
# Kaybedenler veritabanındaki şifreli verilere erişemez!
ENCRYPTION_KEY=buraya-64-karakter-hex-string-koy

# ── VERİTABANI ────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=voiceai
POSTGRES_USER=voiceai_user
POSTGRES_PASSWORD=guclu-sifre-buraya

# ── REDIS ─────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis-sifre-buraya

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET_KEY=jwt-icin-cok-uzun-rastgele-string
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── ASTERISK ──────────────────────────────────────────────────
ASTERISK_ARI_HOST=asterisk
ASTERISK_ARI_PORT=8088
ASTERISK_ARI_USER=voiceai
ASTERISK_ARI_PASSWORD=asterisk-ari-sifre

# NOT: SIP sağlayıcı bilgileri (Netgsm, Verimor) ve diğer tüm
# API anahtarları artık admin paneli üzerinden yönetilir.
# Şifreli olarak PostgreSQL'e kaydedilir.
# Aşağıdaki alanlar sadece ilk bootstrap için kullanılır.

# ── NETGSM SIP (Bootstrap) ────────────────────────────────────
NETGSM_SIP_HOST=sip.netgsm.com.tr
NETGSM_SIP_USER=05XXXXXXXXX
NETGSM_SIP_PASSWORD=netgsm-sip-sifre

# ── NETGSM SMS (Bootstrap) ────────────────────────────────────
NETGSM_SMS_USERNAME=05XXXXXXXXX
NETGSM_SMS_PASSWORD=netgsm-sms-sifre
NETGSM_SMS_HEADER=FIRMAADINIZ

# ── OLLAMA / LLM ──────────────────────────────────────────────
OLLAMA_HOST=ollama
OLLAMA_PORT=11434
OLLAMA_MODEL=atasoglu/Turkish-Llama-3-8B-function-calling

# ── FASTER-WHISPER ────────────────────────────────────────────
WHISPER_HOST=whisper
WHISPER_PORT=9000
WHISPER_MODEL=turbo
WHISPER_COMPUTE_TYPE=int8
WHISPER_LANGUAGE=tr

# ── XTTS-v2 TTS ───────────────────────────────────────────────
XTTS_HOST=xtts
XTTS_PORT=5002
XTTS_DEFAULT_VOICE=tr_female_1

# ── YEDEKLEME ─────────────────────────────────────────────────
RCLONE_REMOTE=mybackup
RCLONE_PATH=voiceai-backups
BACKUP_RETENTION_DAYS=30

# ── İZLEME ────────────────────────────────────────────────────
GRAFANA_PASSWORD=grafana-admin-sifre
